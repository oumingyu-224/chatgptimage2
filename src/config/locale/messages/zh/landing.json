  "features": {
    "id": "features",
    "title": "ChatGPT Image 2 核心特性",
    "description": "围绕主关键词 ChatGPT Image 2 构建的现代 AI 图像生成与编辑工作流能力。",
    "items": [
      {
        "title": "高质量生成与编辑一体化",
        "description": "ChatGPT Image 2 同时适合生成新图和编辑已有图片，适合从创意到精修的一体化工作流。",
        "icon": "RiMagicLine"
      },
      {
        "title": "更强的提示词遵循能力",
        "description": "对于构图控制、局部修改、图中文字摆放和商业设计需求，它能更稳定地理解并执行复杂指令。",
        "icon": "RiUserStarLine"
      },
      {
        "title": "参考图保真度更高",
        "description": "上传参考图后，更适合保留风格、主体细节、商品结构或品牌元素，提升图生图编辑的一致性。",
        "icon": "RiLandscapeLine"
      },
      {
        "title": "支持图中文字与透明背景",
        "description": "非常适合社媒海报、商品素材、贴纸、Logo 辅助图等需要图中文字或透明背景输出的场景。",
        "icon": "Layers"
      },
      {
        "title": "多尺寸输出与商业视觉生产",
        "description": "支持多种尺寸，适合电商主图、营销海报、社媒内容和品牌视觉资产等商用场景。",
        "icon": "RiAspectRatioLine"
      },
      {
        "title": "质量优先的图像输出",
        "description": "它的定位更偏向高质量而不是最低延迟，因此复杂任务可能更耗时，但更适合成品级视觉内容。",
        "icon": "RiFlashlightLine"
      }
    ]
  },
