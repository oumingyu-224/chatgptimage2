  "features": {
    "id": "features",
    "title": "Flux Klein 核心特性",
    "description": "借助基于 Flux 的领先 AI 影像模型 Flux Klein，获取生成与优化视觉作品所需的一切。",
    "items": [
      {
        "title": "超写实纹理生成",
        "description": "告别 AI 的“平滑感”。Flux Klein 专注于微米级皮肤孔隙、发丝绒毛及织物纹理的细腻还原，生成具有呼吸感的超写实影像。",
        "icon": "RiMagicLine"
      },
      {
        "title": "顶尖指令遵循",
        "description": "完美解读复杂的摄影指令。无论是特定的镜头焦段、构图角度还是极其细腻的光位分布，Flux Klein 都能精准还原您的文本意图。",
        "icon": "RiUserStarLine"
      },
      {
        "title": "电影级光影与光学景深",
        "description": "模拟真实的光学折射与动态范围。利用 Flux 架构的深度感知能力，自动平衡画面明暗，呈现具有电影质感的光影层次与自然虚化。",
        "icon": "RiLandscapeLine"
      },
      {
        "title": "视觉特征一致性",
        "description": "专为连贯性艺术创作优化。在多轮生成或不同场景切换中，Flux Klein 能更好地保持人物面部特征与风格基调，满足专业叙事需求。",
        "icon": "Layers"
      },
      {
        "title": "专业级构图与画幅控制",
        "description": "原生支持全画幅比例构图。在 1:1 到 21:9 的超宽比例下，模型能自适应重构人体解剖与透视关系，确保画面边缘无畸变。",
        "icon": "RiAspectRatioLine"
      },
      {
        "title": "即时高保真变体迭代",
        "description": "秒级生成多样化采样方案。在不改变核心构图的前提下，让您能够快速探索不同的光效方案、材质表现和色彩饱和度变体。",
        "icon": "RiFlashlightLine"
      }
    ]
  },
